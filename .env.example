# Alpaca credentials — get these from alpaca.markets
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Set to "false" when switching to a live account
ALPACA_PAPER=true

# Data feed: "iex" (free, works with paper) or "sip" (live accounts only)
ALPACA_DATA_FEED=iex

# Ollama configuration — change OLLAMA_MODEL to swap the LLM
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen3:8b
